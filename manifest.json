{
  "manifest_version": 3,
  "name": "1.도서 목록 매칭 매니저",
  "version": "1.28.1",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "contextMenus", 
    "storage", 
    "unlimitedStorage",
    "activeTab", 
    "scripting", 
    "downloads", 
    "alarms",
    "cookies",
    "sidePanel"
  ],
  "host_permissions": [
    "https://transfer.it/*",
    "https://*.api.mega.co.nz/*",
    "https://*.userstorage.mega.co.nz/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "options.html#sidepanel"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["common.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}